---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import ShowCard from '../../components/ShowCard.astro';
import { withBase } from '../../utils/withBase';

export async function getStaticPaths() {
  const shows = await getCollection('shows');
  return shows.map((show) => ({
    params: { slug: show.id },
    props: { show },
  }));
}

const { show } = Astro.props;
const { title, tagline, hero, imageAlt, gallery, facts, credits, why, experience } = show.data;
const { Content } = await render(show);

const others = (await getCollection('shows'))
  .filter((s) => s.id !== show.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Base title={`${title} — Teater För Alla`} description={tagline}>
  <article>
    <header class="show-head">
      <div class="container">
        <nav class="crumbs" aria-label="Brödsmulor">
          <a href={withBase('/forestallningar/')}>Föreställningar</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{title}</span>
        </nav>
        <h1>{title}</h1>
        <p class="show-tagline">{tagline}</p>
      </div>
      <div class="container">
        <div class="photo show-hero reveal">
          <Image
            src={hero}
            alt={imageAlt}
            widths={[768, 1200, 1600]}
            sizes="(max-width: 1200px) 96vw, 1140px"
            loading="eager"
          />
        </div>
      </div>
    </header>

    <div class="container show-layout">
      <div class="show-main">
        <h2 class="block-title">Om föreställningen</h2>
        <div class="prose reveal">
          <Content />
        </div>

        {
          why.length > 0 && (
            <section class="why reveal">
              <h2 class="block-title">Därför välja denna föreställning</h2>
              <ul>
                {why.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </section>
          )
        }

        {
          experience && (
            <section class="experience reveal">
              <h2 class="block-title">Erfarenhet & samarbeten</h2>
              <p>{experience}</p>
            </section>
          )
        }

        {
          gallery.length > 0 && (
            <section class="gallery reveal" aria-label="Bilder från föreställningen">
              <h2 class="block-title">Bilder</h2>
              <div class="gallery-grid">
                {gallery.map((img) => (
                  <div class="photo gallery-item">
                    <Image src={img} alt={`Scen ur ${title}`} widths={[480, 768]} sizes="(max-width: 640px) 92vw, 360px" />
                  </div>
                ))}
              </div>
            </section>
          )
        }
      </div>

      <aside class="show-aside">
        <div class="card facts reveal">
          <h2>Snabbfakta</h2>
          <dl>
            {
              facts.map((fact) => (
                <div class="fact">
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              ))
            }
          </dl>

          {
            credits.length > 0 && (
              <>
                <h2 class="credits-title">Medverkande</h2>
                <dl>
                  {credits.map((credit) => (
                    <div class="fact">
                      <dt>{credit.role}</dt>
                      <dd>{credit.name}</dd>
                    </div>
                  ))}
                </dl>
              </>
            )
          }

          <a href={withBase('/kontakt/')} class="btn btn--primary booking-btn">
            Boka föreställningen <span class="arrow" aria-hidden="true">→</span>
          </a>
          <p class="facts-note">
            Vi spelar på teatrar, skolor, bibliotek och festivaler — tekniken anpassas efter
            er lokal.
          </p>
        </div>
      </aside>
    </div>

    <section class="section more" aria-labelledby="fler-titel">
      <div class="container">
        <p class="eyebrow reveal">Mer ur repertoaren</p>
        <h2 class="section-title reveal" id="fler-titel">Fler föreställningar</h2>
        <div class="show-grid more-grid">
          {others.map((other, i) => <ShowCard show={other} index={i} />)}
        </div>
      </div>
    </section>
  </article>
</Base>

<style>
  .show-head {
    padding-top: clamp(2.5rem, 2rem + 2vw, 4.5rem);
  }

  .crumbs {
    display: flex;
    gap: 0.6rem;
    font-size: var(--step--1);
    color: var(--muted);
    margin-bottom: 1.6rem;
  }

  .crumbs a {
    color: var(--muted);
    text-decoration: none;
  }

  .crumbs a:hover {
    color: var(--accent);
  }

  .show-head h1 {
    font-size: var(--step-5);
    max-width: 20ch;
  }

  .show-tagline {
    margin-top: 1rem;
    font-size: var(--step-1);
    color: var(--ink-soft);
    max-width: 52ch;
  }

  .show-hero {
    margin-top: clamp(1.8rem, 3vw, 2.8rem);
    aspect-ratio: 21 / 9;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
  }

  .show-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20rem;
    gap: clamp(2rem, 5vw, 4.5rem);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
    align-items: start;
  }

  .block-title {
    font-size: var(--step-2);
    margin-bottom: 0.9rem;
  }

  .show-main > * + * {
    margin-top: clamp(2.2rem, 4vw, 3.2rem);
  }

  .why ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .why li {
    position: relative;
    padding-left: 1.7rem;
    color: var(--ink-soft);
  }

  .why li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .experience p {
    color: var(--ink-soft);
    max-width: 62ch;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: 1rem;
  }

  .gallery-item {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
  }

  .gallery-item:hover img {
    transform: scale(1.04);
  }

  .show-aside {
    position: sticky;
    top: 5.5rem;
  }

  .facts {
    padding: 1.75rem;
  }

  .facts h2 {
    font-size: var(--step-1);
    margin-bottom: 1.1rem;
  }

  .credits-title {
    margin-top: 1.5rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
  }

  .booking-btn {
    width: 100%;
    justify-content: center;
    margin-top: 1.6rem;
  }

  .facts-note {
    margin-top: 1rem;
    font-size: var(--step--1);
    color: var(--muted);
  }

  .more {
    background: var(--paper-deep);
    border-top: 1px solid var(--line);
  }

  .more-grid {
    margin-top: 2.5rem;
  }

  @media (max-width: 860px) {
    .show-layout {
      grid-template-columns: 1fr;
    }

    .show-aside {
      position: static;
    }

    .show-hero {
      aspect-ratio: 16 / 10;
    }
  }
</style>
