---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ShowCard from '../../components/ShowCard.astro';
import { withBase } from '../../utils/withBase';

const shows = (await getCollection('shows')).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Föreställningar — Teater För Alla"
  description="Interaktiva och berörande föreställningar som kombinerar dockteater, musik och berättande för barn, familjer och skolor. Boka till er scen, skola eller bibliotek."
>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow reveal">Repertoar</p>
      <h1 class="section-title reveal">Föreställningar</h1>
      <p class="lede reveal">
        Interaktiva och berörande föreställningar som kombinerar dockteater, musik och
        berättande — för barn, familjer och skolor. Alla föreställningar kan bokas till
        teatrar, skolor, bibliotek och festivaler.
      </p>
    </div>
  </section>

  <section class="container" aria-label="Alla föreställningar">
    <div class="show-grid">
      {shows.map((show, i) => <ShowCard show={show} index={i} />)}
    </div>
  </section>

  <section class="section">
    <div class="container booking-note reveal">
      <h2>Hittar ni inte det ni söker?</h2>
      <p>
        Vi skräddarsyr gärna föreställningar och program för er publik, ert tema eller ert
        evenemang. <a href={withBase('/kontakt/')}>Hör av er</a> så hittar vi något tillsammans.
      </p>
    </div>
  </section>
</Base>

<style>
  .booking-note {
    text-align: center;
    max-width: 44rem;
  }

  .booking-note h2 {
    font-size: var(--step-3);
  }

  .booking-note p {
    margin-top: 0.8rem;
    color: var(--ink-soft);
  }
</style>
