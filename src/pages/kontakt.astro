---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';

import kontaktBild from '../assets/site/kontakt.jpg';

const channels = [
  {
    label: 'E-post',
    value: 'info@teaterforalla.se',
    href: 'mailto:info@teaterforalla.se',
    note: 'Bokningar, samarbeten och allmänna frågor.',
  },
  {
    label: 'Telefon',
    value: '+46 76 702 26 40',
    href: 'tel:+46767022640',
    note: 'Även +46 72 299 51 76.',
  },
  {
    label: 'Här finns vi',
    value: 'Järfälla · Stockholm · Malmö',
    href: undefined,
    note: 'Vi turnerar i hela landet — avstånd är sällan ett hinder.',
  },
];
---

<Base
  title="Kontakt & bokning — Teater För Alla"
  description="Vi välkomnar frågor och samarbeten kring konst och teater. Tveka inte att höra av dig — boka föreställning eller workshop via e-post eller telefon."
>
  <section class="page-head">
    <div class="container">
      <p class="eyebrow reveal">Kontakt & bokning</p>
      <h1 class="section-title reveal">Kontakta oss</h1>
      <p class="lede reveal">
        Vi välkomnar frågor och samarbeten kring konst och teater. Tveka inte att höra av
        dig till oss för mer information — vi återkommer med förslag.
      </p>
    </div>
  </section>

  <section class="container contact-layout" aria-label="Kontaktuppgifter och bokningsförfrågan">
    <div class="contact-left">
      <div class="photo contact-photo reveal">
        <Image src={kontaktBild} alt="Scen ur en föreställning med Teater För Alla" widths={[600, 900, 1200]} sizes="(max-width: 820px) 92vw, 520px" loading="eager" />
      </div>
      <div class="channel-list">
        {
          channels.map((channel, i) => (
            <div class="card channel reveal" style={`--reveal-delay: ${i * 0.08}s`}>
              <h2>{channel.label}</h2>
              {channel.href ? (
                <a href={channel.href} class="channel-value">
                  {channel.value}
                </a>
              ) : (
                <p class="channel-value">{channel.value}</p>
              )}
              <p class="channel-note">{channel.note}</p>
            </div>
          ))
        }
        <div class="card channel reveal" style="--reveal-delay: 0.24s">
          <h2>Sociala medier</h2>
          <p class="channel-value socials">
            <a href="https://www.instagram.com/teaterforalla" rel="noopener">Instagram</a>
            <a href="https://www.facebook.com/teaterforalla" rel="noopener">Facebook</a>
            <a href="https://www.linkedin.com/" rel="noopener">LinkedIn</a>
          </p>
          <p class="channel-note">Premiärer, turnédatum och bilder från verkstaden.</p>
        </div>
      </div>
    </div>

    <form
      class="card booking-form reveal"
      action="mailto:info@teaterforalla.se"
      method="get"
      style="--reveal-delay: 0.1s"
    >
      <h2>Skicka meddelande</h2>
      <p class="form-intro">Fyll i formuläret så öppnas ett färdigt e-postutkast till oss.</p>

      <div class="field">
        <label for="subject">Vad gäller det?</label>
        <select id="subject" name="subject" required>
          <option value="Bokningsförfrågan: föreställning">Boka en föreställning</option>
          <option value="Bokningsförfrågan: workshop">Boka en workshop</option>
          <option value="Intresseanmälan: teaterkurs">Teaterkursen våren 2026</option>
          <option value="Samarbetsförfrågan">Samarbete & sponsring</option>
          <option value="Övrig fråga">Något annat</option>
        </select>
      </div>

      <div class="field">
        <label for="body">Berätta mer</label>
        <textarea
          id="body"
          name="body"
          rows="7"
          required
          placeholder="Vilka är ni, var finns ni och vad önskar ni? Glöm inte hur vi når er!"
        ></textarea>
      </div>

      <button type="submit" class="btn btn--primary">
        Öppna e-postutkast <span class="arrow" aria-hidden="true">→</span>
      </button>
      <p class="form-note">
        Formuläret använder ert eget e-postprogram — inga uppgifter lagras på webbplatsen.
      </p>
    </form>
  </section>
</Base>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
    padding-bottom: var(--space-section);
  }

  .contact-photo {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-card);
    margin-bottom: 1.5rem;
  }

  .channel-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .channel {
    padding: 1.4rem 1.5rem;
  }

  .channel h2 {
    font-family: var(--font-body);
    font-size: var(--step--1);
    font-weight: 680;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .channel-value {
    display: block;
    margin-top: 0.35rem;
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--ink);
    text-decoration: none;
    overflow-wrap: anywhere;
  }

  a.channel-value:hover {
    color: var(--accent);
  }

  .socials {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .socials a {
    color: var(--ink);
    text-decoration: none;
  }

  .socials a:hover {
    color: var(--accent);
  }

  .channel-note {
    margin-top: 0.4rem;
    font-size: var(--step--1);
    color: var(--muted);
  }

  .booking-form {
    padding: clamp(1.75rem, 3vw, 2.5rem);
  }

  .booking-form h2 {
    font-size: var(--step-2);
  }

  .form-intro {
    margin-top: 0.5rem;
    color: var(--muted);
    font-size: var(--step--1);
  }

  .field {
    margin-top: 1.4rem;
    display: grid;
    gap: 0.45rem;
  }

  .field label {
    font-weight: 620;
    font-size: var(--step--1);
  }

  .field select,
  .field textarea {
    width: 100%;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    color: var(--ink);
    font: inherit;
    font-size: var(--step--1);
    padding: 0.8rem 0.9rem;
    resize: vertical;
  }

  .field select:focus-visible,
  .field textarea:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
    border-color: var(--accent);
  }

  .booking-form .btn {
    margin-top: 1.6rem;
    width: 100%;
    justify-content: center;
  }

  .form-note {
    margin-top: 0.9rem;
    font-size: var(--step--1);
    color: var(--muted);
    text-align: center;
  }

  @media (max-width: 820px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 540px) {
    .channel-list {
      grid-template-columns: 1fr;
    }
  }
</style>
