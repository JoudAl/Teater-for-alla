---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import WorkshopCard from '../../components/WorkshopCard.astro';
import { withBase } from '../../utils/withBase';

export async function getStaticPaths() {
  const workshops = await getCollection('workshops');
  return workshops.map((workshop) => ({
    params: { slug: workshop.id },
    props: { workshop },
  }));
}

const { workshop } = Astro.props;
const { title, tagline, image, imageAlt, gallery, facts, what, why, badge } = workshop.data;
const { Content } = await render(workshop);

const others = (await getCollection('workshops'))
  .filter((w) => w.id !== workshop.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Base title={`${title} — Teater För Alla`} description={tagline}>
  <article>
    <header class="ws-head">
      <div class="container ws-head-grid">
        <div>
          <nav class="crumbs" aria-label="Brödsmulor">
            <a href={withBase('/workshops/')}>Workshops</a>
            <span aria-hidden="true">/</span>
            <span aria-current="page">{title}</span>
          </nav>
          {badge && <span class="badge">{badge}</span>}
          <h1>{title}</h1>
          <p class="ws-tagline">{tagline}</p>
          <a href={withBase('/kontakt/')} class="btn btn--primary">
            Boka workshopen <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
        <div class="photo ws-hero reveal">
          <Image
            src={image}
            alt={imageAlt}
            widths={[600, 900, 1200]}
            sizes="(max-width: 880px) 92vw, 520px"
            loading="eager"
          />
        </div>
      </div>
    </header>

    <div class="container ws-layout">
      <div class="ws-main">
        <h2 class="block-title">Om workshopen</h2>
        <div class="prose reveal">
          <Content />
        </div>

        {
          what.length > 0 && (
            <section class="listing reveal">
              <h2 class="block-title">Vad vi gör</h2>
              <ul>
                {what.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </section>
          )
        }

        {
          why.length > 0 && (
            <section class="listing reveal">
              <h2 class="block-title">Därför välja denna workshop</h2>
              <ul>
                {why.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </section>
          )
        }

        {
          gallery.length > 0 && (
            <section class="gallery reveal" aria-label="Bilder från workshopen">
              <h2 class="block-title">Bilder</h2>
              <div class="gallery-grid">
                {gallery.map((img) => (
                  <div class="photo gallery-item">
                    <Image src={img} alt={`Bild från ${title}`} widths={[480, 768]} sizes="(max-width: 640px) 92vw, 360px" />
                  </div>
                ))}
              </div>
            </section>
          )
        }
      </div>

      <aside class="ws-aside">
        <div class="card facts reveal">
          <h2>Praktisk information</h2>
          <dl>
            {
              facts.map((fact) => (
                <div class="fact">
                  <dt>{fact.label}</dt>
                  <dd>{fact.value}</dd>
                </div>
              ))
            }
          </dl>
          <a href={withBase('/kontakt/')} class="btn btn--primary booking-btn">
            Boka & fråga <span class="arrow" aria-hidden="true">→</span>
          </a>
          <p class="facts-note">
            Upplägget anpassas efter grupp, ålder och lokal — hör av er så hittar vi rätt
            form för er.
          </p>
        </div>
      </aside>
    </div>

    <section class="section more" aria-labelledby="fler-ws-titel">
      <div class="container">
        <p class="eyebrow reveal">Mer att skapa</p>
        <h2 class="section-title reveal" id="fler-ws-titel">Fler workshops</h2>
        <div class="show-grid more-grid">
          {others.map((other, i) => <WorkshopCard workshop={other} index={i} />)}
        </div>
      </div>
    </section>
  </article>
</Base>

<style>
  .ws-head {
    padding-top: clamp(2.5rem, 2rem + 2vw, 4.5rem);
  }

  .ws-head-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .crumbs {
    display: flex;
    gap: 0.6rem;
    font-size: var(--step--1);
    color: var(--muted);
    margin-bottom: 1.6rem;
  }

  .crumbs a {
    color: var(--muted);
    text-decoration: none;
  }

  .crumbs a:hover {
    color: var(--accent);
  }

  .ws-head h1 {
    font-size: var(--step-5);
    max-width: 18ch;
    margin-top: 0.9rem;
  }

  .ws-tagline {
    margin-block: 1rem 1.8rem;
    font-size: var(--step-1);
    color: var(--ink-soft);
    max-width: 44ch;
  }

  .ws-hero {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-lift);
  }

  .ws-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20rem;
    gap: clamp(2rem, 5vw, 4.5rem);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
    align-items: start;
  }

  .block-title {
    font-size: var(--step-2);
    margin-bottom: 0.9rem;
  }

  .ws-main > * + * {
    margin-top: clamp(2.2rem, 4vw, 3.2rem);
  }

  .listing ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .listing li {
    position: relative;
    padding-left: 1.7rem;
    color: var(--ink-soft);
  }

  .listing li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: 1rem;
  }

  .gallery-item {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line);
  }

  .gallery-item:hover img {
    transform: scale(1.04);
  }

  .ws-aside {
    position: sticky;
    top: 5.5rem;
  }

  .facts {
    padding: 1.75rem;
  }

  .facts h2 {
    font-size: var(--step-1);
    margin-bottom: 1.1rem;
  }

  .booking-btn {
    width: 100%;
    justify-content: center;
    margin-top: 1.6rem;
  }

  .facts-note {
    margin-top: 1rem;
    font-size: var(--step--1);
    color: var(--muted);
  }

  .more {
    background: var(--paper-deep);
    border-top: 1px solid var(--line);
  }

  .more-grid {
    margin-top: 2.5rem;
  }

  @media (max-width: 880px) {
    .ws-head-grid,
    .ws-layout {
      grid-template-columns: 1fr;
    }

    .ws-aside {
      position: static;
    }
  }
</style>
